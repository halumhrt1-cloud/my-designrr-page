<script>
(function(){
  var key='dsgn_cd_end', stored=localStorage.getItem(key), end;
  if(stored){end=parseInt(stored,10);}else{end=Date.now()+(24*60*60*1000);localStorage.setItem(key,end);}
  function pad(n){return n<10?'0'+n:n;}
  function tick(){
    var d=Math.max(0,end-Date.now());
    document.getElementById('cd-hours').textContent=pad(Math.floor(d/3600000));
    document.getElementById('cd-mins').textContent=pad(Math.floor((d%3600000)/60000));
    document.getElementById('cd-secs').textContent=pad(Math.floor((d%60000)/1000));
    if(d>0)setTimeout(tick,1000);
  }
  tick();
})();
</script>
